---
import ColumnLayout from "src/layouts/ColumnLayout.astro";
import GridCard from "src/components/GridCard.astro";
import Pager from "src/components/Pager.astro";

import { getCollection } from "astro:content";
import type { GetStaticPaths } from "astro";
export const getStaticPaths = (async ({ paginate }) => {
	// 記事データ取得
	const allPosts = await getCollection("blog");
	// 記事データを新しい順に並べ替え
	const sortedPosts = allPosts.sort((a, b) => {
		const aDate = new Date(a.data.publishDate).getTime();
		const bDate = new Date(b.data.publishDate).getTime();
		return bDate - aDate;
	});
	return paginate(sortedPosts, { pageSize: 1 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<ColumnLayout>
	<GridCard posts={page.data} />
	<Pager page={page} />
</ColumnLayout>
