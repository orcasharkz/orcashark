---
import "@fontsource-variable/m-plus-1";
import "src/styles/global.css";
import MetaTag from "src/components/MetaTag.astro";
import Header from "src/components/Header.astro";
import Footer from "src/components/Footer.astro";

interface Props {
	baseData: {
		title: string;
	};
}
const { baseData } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<MetaTag metaData={{ baseData }} />
		<title>{baseData.title}</title>
		<link rel="icon" href="/orcashark/uploads/favicon.ico" />
		<link rel="apple-touch-icon" href="/orcashark/uploads/a-icon.png" />
	</head>
	<body>
		<div id="container">
			<Header />
			<slot />
			<Footer />
		</div>
		<script>
			import "src/scripts/main";
		</script>
	</body>
</html>

<style>
	#container {
		@media (768px<=width) {
			width: min(93%, 1300px);
			margin-inline: auto;
		}
	}
</style>
